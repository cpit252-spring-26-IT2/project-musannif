               <styleClass>
                  <String fx:value="nav-button" />
                  <String fx:value="nav-button-active" />
               </styleClass>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <SplitPane dividerPositions="0.5" prefHeight="160.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <items>
          <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="0.0" minWidth="0.0" prefHeight="643.0" prefWidth="212.0">
               <children>
                  <VBox layoutY="2.0" maxWidth="-Infinity" prefHeight="598.0" prefWidth="217.0">
                     <children>
                        <Label text="1. Target Folder" textAlignment="CENTER" />
                        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                           <children>
                              <TextField fx:id="txtFolderPath" prefWidth="174.0" />
                              <Button fx:id="btnBrowse" mnemonicParsing="false" onAction="#handleBrowse" text="Browse" />
                           </children>
                        </VBox>
                        <Region maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="33.0" prefWidth="177.0" />
                        <Label text="2. Organize By" textAlignment="CENTER" />
                        <VBox>
                           <children>
                              <RadioButton fx:id="radioExtension" mnemonicParsing="false" selected="true" text="File Extension">
                                 <toggleGroup>
                                    <ToggleGroup fx:id="orgGroup" />
                                 </toggleGroup>
                              </RadioButton>
                              <RadioButton fx:id="radioType" mnemonicParsing="false" text="File Type" toggleGroup="$orgGroup" />
                              <RadioButton fx:id="radioDate" mnemonicParsing="false" text="Date Modified" toggleGroup="$orgGroup" />
                           </children>
                        </VBox>
                        <Region maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="33.0" prefWidth="177.0" />
                        <Label text="3. Action" textAlignment="CENTER" />
                        <HBox prefHeight="100.0" prefWidth="200.0">
                           <children>
                              <Button fx:id="btnScan" mnemonicParsing="false" onAction="#handleScan" text="Scan Folder" />
                              <Button fx:id="btnApply" mnemonicParsing="false" onAction="#handleApply" prefHeight="25.0" prefWidth="84.0" text="Apply" translateX="20.0" />
                           </children>
                        </HBox>
                        <HBox prefHeight="100.0" prefWidth="200.0">
                           <children>
                              <ProgressBar fx:id="scanProgress" progress="0.0" />
                           </children>
                        </HBox>
                        <StackPane prefHeight="600.0" prefWidth="117.0">
                           <children>
                              <VBox prefHeight="423.0" prefWidth="228.0" />
                           </children>
                        </StackPane>
                     </children>
                     <opaqueInsets>
                        <Insets left="20.0" right="20.0" />
                     </opaqueInsets>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </children>
            </AnchorPane>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="629.0" prefWidth="532.0">
               <children>
                  <Label layoutX="178.0" layoutY="293.0" text="No files scannned yet.">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </center>
</BorderPane>
