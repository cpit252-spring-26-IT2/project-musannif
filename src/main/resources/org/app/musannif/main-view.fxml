<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.app.musannif.controller.MainController">
   <top>
      <HBox prefHeight="47.0" prefWidth="900.0" spacing="15.0" style="-fx-background-color: #1D9E75;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Region prefHeight="60.0" prefWidth="245.0" />
            <VBox prefHeight="60.0" prefWidth="481.0">
               <children>
                  <Label alignment="CENTER" contentDisplay="TOP" prefHeight="21.0" prefWidth="171.0" text="Musannif - مصنف" textAlignment="CENTER" textFill="WHITE" textOverrun="WORD_ELLIPSIS" translateX="125.0">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" contentDisplay="TOP" prefHeight="21.0" prefWidth="171.0" text="file organizer" textAlignment="CENTER" textFill="WHITE" textOverrun="WORD_ELLIPSIS" translateX="125.0">
                     <font>
                        <Font name="System Italic" size="12.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <Region prefHeight="60.0" prefWidth="130.0" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" prefHeight="42.0" prefWidth="44.0" styleClass="credits-button" stylesheets="@styles.css" text="ⓘ" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox prefHeight="19.0" prefWidth="900.0" style="-fx-background-color: #777777;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="TOP_RIGHT" text="Status: ">
               <padding>
                  <Insets left="20.0" />
               </padding>
            </Label>
         </children>
      </HBox>
   </bottom>
   <left>
      <VBox prefHeight="200.0" prefWidth="150.0" style="-fx-background-color: #2c3338;" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="organizeBtn" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleOrganize" prefHeight="30.0" prefWidth="153.0" stylesheets="@styles.css" text="Organize">
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
               <styleClass>
                  <String fx:value="nav-button" />
                  <String fx:value="nav-button-active" />
               </styleClass>
            </Button>
            <Button fx:id="previewBtn" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handlePreview" prefHeight="30.0" prefWidth="153.0" stylesheets="@styles.css" text="Preview">
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
               <styleClass>
                  <String fx:value="nav-button" />
                  <String fx:value="nav-button-active" />
               </styleClass>
            </Button>
            <Button fx:id="historyBtn" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleHistory" prefHeight="30.0" prefWidth="153.0" stylesheets="@styles.css" text="History">
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
               <styleClass>
                  <String fx:value="nav-button" />
                  <String fx:value="nav-button-active" />
               </styleClass>
            </Button>
            <Region prefHeight="454.0" prefWidth="150.0" />
            <Button fx:id="settingsBtn" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleSettings" prefHeight="30.0" prefWidth="153.0" stylesheets="@styles.css" text="Settings">
